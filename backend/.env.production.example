ENVIRONMENT=production

# PostgreSQL in docker-compose
DATABASE_URL=postgresql://portfolio:portfolio_password@db:5432/portfolio

# Use a long random value in real deployments
SECRET_KEY=change-this-to-a-long-random-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Add your real frontend domain(s)
CORS_ORIGINS=http://localhost,http://127.0.0.1

MAX_IMAGE_SIZE_MB=5
MAX_PDF_SIZE_MB=10
UPLOAD_DIR=uploads
RATE_LIMIT_PER_MINUTE=100
AUTO_CREATE_TABLES=false
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FORCE_RESET=false

HOST=0.0.0.0
PORT=8000
